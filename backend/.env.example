# Elastic Cloud Serverless Configuration
# The URL should look like: https://your-serverless-deployment.es.us-east-1.aws.elastic.cloud:443 or similar
ELASTICSEARCH_URL=https://<your-serverless-deployment-id>.<region>.aws.elastic.cloud:443
ELASTICSEARCH_API_KEY=<your-api-key-here>

# LLM Provider Configuration (OpenAI, Gemini, etc.)
# To use Gemini via Google AI Studio (Recommended for standard prototyping):
GOOGLE_API_KEY=AIzaSy...
MODEL_NAME=gemini-1.5-flash # or gemini-1.5-pro

# To use Gemini via Vertex AI (GCP Agent Platform Model API):
# USE_VERTEX_AI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Or fallback to OpenAI:
# OPENAI_API_KEY=sk-proj-...
# MODEL_NAME=gpt-4o


# Server settings
PORT=8000
HOST=0.0.0.0
